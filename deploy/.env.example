# ============================================================
# Jarvis persistent stack — environment variables
# Copy this file to deploy/.env and fill in your values.
# NEVER commit deploy/.env to git.
# ============================================================

# ── Discord bot ──────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Name of the Discord text channel Jarvis listens to
DISCORD_CHANNEL_NAME=jarvis

# Optional command prefix (default: !ask)
DISCORD_PREFIX=!ask

# Webhook URL for digest posts — created in Discord channel settings
# Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_DIGEST_WEBHOOK=https://discord.com/api/webhooks/...

# Guild (server) ID for instant slash-command sync on startup.
# Right-click your server icon → Copy Server ID (requires Developer Mode).
# Without this, slash commands still sync but take up to 1 hour to appear.
DISCORD_GUILD_ID=1483495539931746357

# ── Digest scheduler ─────────────────────────────────────────
# How often to run the HN digest (in days, supports decimals e.g. 0.5 = 12h)
DIGEST_INTERVAL_DAYS=3

# Number of top stories to include
DIGEST_TOP_N=15

# Minimum HN score to include a story
DIGEST_MIN_SCORE=30

# ── GitHub integration ───────────────────────────────────────
# Personal access token — needs: repo (read + write issues)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# The repo the claude-worker will read issues from and the codebase it works on
# Format: owner/repo  ← point this at YOUR fork, not the upstream OpenJarvis repo
GITHUB_REPO=blackpandachan/JarvisPanda

# ── Anthropic / Claude Code ──────────────────────────────────
# Required for the ClaudeCodeAgent worker.
# Get from: https://console.anthropic.com/settings/keys
# Leave blank to run the stack without Claude Code — the worker
# will start but skip issue processing until the key is set.
ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini (mid-tier escalation) ─────────────────────────────
# Second escalation tier — used before cutting a GitHub issue.
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Model to use (default: gemini-2.5-flash-preview)
GEMINI_MODEL=gemini-2.5-flash-preview

# ── Optional: Tavily web search (richer results than DuckDuckGo) ─
# Free tier at: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ── Weather (discord !weather command) ───────────────────────
# Default city when !weather is used without a city argument
DEFAULT_WEATHER_CITY=New York

# ── Claude Code worker tuning ────────────────────────────────
# How often to poll GitHub for new issues (seconds)
POLL_INTERVAL=300

# Skip issues older than this many days
MAX_ISSUE_AGE_DAYS=14

# Merge strategy: manual (default) | auto | comment
# manual = post PR + guide, wait for !merge or 👍
# auto   = post PR + guide, auto-merge after MERGE_DELAY_MINUTES
# comment = legacy: post output as issue comment (no branch/PR)
MERGE_STRATEGY=manual

# Minutes to wait before auto-merge (only applies when MERGE_STRATEGY=auto)
MERGE_DELAY_MINUTES=15

# Base branch to create PRs against (default: main)
DEFAULT_BRANCH=main

# ── GitHub webhook (instant issue pickup) ────────────────────
# Set a random secret, then create a webhook in your repo:
#   Settings → Webhooks → Add webhook
#   Payload URL: http://<your-host>:9000
#   Content type: application/json
#   Secret: same value as GITHUB_WEBHOOK_SECRET
#   Events: Issues
# Without this the worker falls back to polling every POLL_INTERVAL seconds.
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_PORT=9000

# ── Observer agent ───────────────────────────────────────────
# How often to run a health observation cycle (seconds, default 1800 = 30m)
OBSERVER_INTERVAL=1800

# UTC hour to post the daily arXiv AI digest (0-23, set to -1 to disable)
OBSERVER_ARXIV_HOUR=8
