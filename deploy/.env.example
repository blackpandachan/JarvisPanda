# ============================================================
# Jarvis persistent stack — environment variables
# Copy this file to deploy/.env and fill in your values.
# NEVER commit deploy/.env to git.
# ============================================================

# ── Discord bot ──────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Name of the Discord text channel Jarvis listens to
DISCORD_CHANNEL_NAME=jarvis

# Optional command prefix (default: !ask)
DISCORD_PREFIX=!ask

# Webhook URL for digest posts — created in Discord channel settings
# Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_DIGEST_WEBHOOK=https://discord.com/api/webhooks/...

# ── Digest scheduler ─────────────────────────────────────────
# How often to run the HN digest (in days, supports decimals e.g. 0.5 = 12h)
DIGEST_INTERVAL_DAYS=3

# Number of top stories to include
DIGEST_TOP_N=15

# Minimum HN score to include a story
DIGEST_MIN_SCORE=30

# ── GitHub integration ───────────────────────────────────────
# Personal access token — needs: repo (read + write issues)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# The repo the claude-worker will read issues from and the codebase it works on
# Format: owner/repo
GITHUB_REPO=open-jarvis/OpenJarvis

# ── Anthropic / Claude Code ──────────────────────────────────
# Required for the ClaudeCodeAgent worker.
# Get from: https://console.anthropic.com/settings/keys
# Leave blank to run the stack without Claude Code — the worker
# will start but skip issue processing until the key is set.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Tavily web search (richer results than DuckDuckGo) ─
# Free tier at: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ── Claude Code worker tuning ────────────────────────────────
# How often to poll GitHub for new issues (seconds)
POLL_INTERVAL=300

# Skip issues older than this many days
MAX_ISSUE_AGE_DAYS=14
